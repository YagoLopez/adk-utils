{
  "name": "@yagolopez/adk-utils",
  "description": "A set of utilities for developing TypeScript agents using Google Agent Development Kit (ADK)",
  "keywords": [
    "adk",
    "adk-tools",
    "ollama",
    "google agent development kit",
    "vercel ai sdk",
    "ai streaming",
    "nextjs",
    "yagolopez",
    "yago"
  ],
  "version": "0.2.7",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "release": "commit-and-tag-version",
    "release:dry-run": "commit-and-tag-version --dry-run",
    "release:publish": "npm run release && npm publish"
  },
  "peerDependencies": {
    "@google/adk": "^0.6.0",
    "@google/genai": "^1.46.0",
    "ai": "^6.0.140",
    "ollama": "^0.6.3"
  },
  "overrides": {
    "tar": "^7.5.11",
    "@tootallnate/once": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "commit-and-tag-version": "^12.7.1",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "lodash": "^4.17.23",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
